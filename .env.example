# Copy to .env and fill in. .env is git-ignored; this file is safe to commit.

# Which model backend llm.ts uses: ais | ollama | gemini-flash | claude-haiku
LLM_PROVIDER=ais

# --- Intelligence Studio (AIS) via App Central gateway ---
INTELLIGENCE_STUDIO_API_KEY="sk-..."
IAM_CLIENT_ID="...-SERVICE"
IAM_CLIENT_SECRET="..."
IAM_TOKEN_URL="https://your-ais-gateway/iam/auth/realms/ais/protocol/openid-connect/token"
AIS_RUN_URL="https://your-ais-gateway/ais/api/v1/run/<flow-id>"

# --- SearXNG (whole-web search) ---
SEARXNG_URL="http://localhost:8080"

# --- Optional fallback providers ---
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.1:8b"
# GEMINI_API_KEY="..."
