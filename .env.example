# Copy to .env and fill in. .env is git-ignored; this file is safe to commit.

# Which model backend llm.ts uses: ais | ollama | gemini-flash | claude-haiku
LLM_PROVIDER=ais

# --- Intelligence Studio (AIS) via App Central gateway ---
INTELLIGENCE_STUDIO_API_KEY="sk-..."
IAM_CLIENT_ID="...-SERVICE"
IAM_CLIENT_SECRET="..."
IAM_TOKEN_URL="https://your-ais-gateway/iam/auth/realms/ais/protocol/openid-connect/token"
AIS_RUN_URL="https://your-ais-gateway/ais/api/v1/run/<flow-id>"

# --- SearXNG (whole-web search) ---
SEARXNG_URL="http://localhost:8080"

# --- LinkedIn auto-posting (official API) ---
# Create an app at developer.linkedin.com, enable "Sign In with LinkedIn (OIDC)"
# + "Share on LinkedIn", and add the redirect URI below. Then run: npm run linkedin:auth
LINKEDIN_CLIENT_ID="..."
LINKEDIN_CLIENT_SECRET="..."
LINKEDIN_REDIRECT_URI="http://localhost:5555/callback"
# Use "openid profile" to test sign-in before the "Share on LinkedIn" product is enabled:
# LINKEDIN_SCOPES="openid profile w_member_social"
LINKEDIN_ACCESS_TOKEN=""
LINKEDIN_AUTHOR_URN=""

# --- Optional fallback providers ---
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.1:8b"
# GEMINI_API_KEY="..."
